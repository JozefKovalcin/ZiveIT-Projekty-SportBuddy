{
  "name": "@sportbuddy/backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--no-warnings' next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@next/swc",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@getbrevo/brevo": "latest",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "better-auth": "latest",
    "next": "latest",
    "openai": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "web-push": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/web-push": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "8.62.0"
  }
}
