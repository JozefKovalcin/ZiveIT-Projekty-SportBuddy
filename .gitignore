node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# pnpm store (local cache)
.pnpm-store/
**/.pnpm-store/

# Testing
coverage/
.nyc_output/

# Next.js (all .next directories in any subdirectory)
.next/
out/
dist/

# Production builds
build/

# Misc
.DS_Store
*.pem
*.log

# Environment files (IMPORTANT: never commit .env with secrets!)
.env
.env.*
!.env.example
.env*.local
.env.production
.env.development.local
.env.test.local
apps/**/.env
apps/**/.env.*
!apps/**/.env.example
komplet_env.md

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma
node_modules/.prisma/
.prisma/
*.db
*.sqlite
*.sqlite3
*.dump
*.bak

# Runtime uploads
apps/backend/public/uploads/
uploads/

# Docker (keep docker-compose.yml and Dockerfiles in Git)
docker-compose.override.yml

# OS
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/
